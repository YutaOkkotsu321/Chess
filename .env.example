# --- Supabase ---
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Site URL ---
# Used as the base for OAuth redirect URLs.
# Local dev: http://localhost:3000
# Production: your Vercel deployment URL (or custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Stripe ---
# Secret key from https://dashboard.stripe.com/apikeys (use sk_test_… in dev)
STRIPE_SECRET_KEY=
# Recurring price ID (price_…) for the Pro plan — create one at
# https://dashboard.stripe.com/products
STRIPE_PRICE_ID=
# Endpoint signing secret from your webhook settings:
# https://dashboard.stripe.com/webhooks   (locally use `stripe listen` and
# paste the whsec_… it prints)
STRIPE_WEBHOOK_SECRET=
# Optional: only needed if you ship a client-side Stripe widget. Not used by
# the current Checkout/Portal redirect flow.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Supabase service role ---
# Required by the Stripe webhook to flip is_pro under RLS. KEEP SECRET — never
# expose this to the browser. Get it from
# https://supabase.com/dashboard/project/_/settings/api (service_role key).
SUPABASE_SERVICE_ROLE_KEY=
